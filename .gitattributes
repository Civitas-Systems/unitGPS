# Normalize line endings so text files stop showing as "modified" after a
# Windows / OneDrive checkout (this is what caused the recurring CRLF churn on
# the .spec and .py files). Text is stored as LF in the repo and checked out LF.
* text=auto eol=lf

# Binary assets — git must never line-ending-munge these.
*.xlsx binary
*.xls  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.gif  binary
*.zip  binary
*.pdf  binary
